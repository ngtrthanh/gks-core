# Export artifacts and signing material — NEVER commit.
# Contains the Ed25519 private key (export/ed25519_key.pem) and CNF dumps.
/export/

# Go build output
/compiler/**/*.test
*.out

# Stray Go build binaries accidentally emitted at the compiler module root
/compiler/falsify
/compiler/interop
# Generated interop CNF exports (regenerate via `go run ./cmd/interop`)
/validation/interop/*.cnf
/compiler/trackd
